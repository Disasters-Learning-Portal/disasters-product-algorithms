"""
CLI entry points for ${Name} processing.
"""

import os


def process_${name}_cli():
    """Entry point for process_${name} command."""

    script_dir = os.path.dirname(os.path.abspath(__file__))
    script_path = os.path.join(script_dir, "process_${name}.py")

    with open(script_path) as f:
        code = compile(f.read(), script_path, "exec")
        exec(code, {"__name__": "__main__"})


if __name__ == "__main__":
    process_${name}_cli()
